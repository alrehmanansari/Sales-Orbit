PORT=5001
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# sqlite  → zero-install file DB (fine for small teams, dev, and low traffic)
# mysql   → use the credentials below (recommended for multi-process / larger teams)
DB_ENGINE=sqlite

# MySQL credentials (only needed when DB_ENGINE=mysql)
DB_HOST=localhost
DB_USER=salesorbit_user
DB_PASSWORD=strong_password_here
DB_NAME=salesorbit

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MS=600000
BCRYPT_ROUNDS=12

# ── Email (OTP delivery) — choose ONE option ─────────────────────────────────
#
# OPTION A  ·  Resend  (recommended — HTTPS, no port issues, 3k free/month)
#   1. Sign up at https://resend.com
#   2. Dashboard → API Keys → Create API Key
#   3. Paste the key below  (leave blank to skip)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
# OPTION B  ·  Gmail SMTP  (requires an App Password, NOT your account password)
#   1. Enable 2-Step Verification: myaccount.google.com → Security
#   2. App Passwords → generate a 16-char password
#   3. Paste it as SMTP_PASS  (leave SMTP_USER blank to skip)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
#
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=SalesOrbit CRM

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the exact public URL where the frontend is served
FRONTEND_URL=https://yourdomain.com
