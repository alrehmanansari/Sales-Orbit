PORT=5001
NODE_ENV=development

# sqlite = zero-install local file  |  mysql = use credentials below
DB_ENGINE=mysql

# MySQL — cPanel: use the DB credentials from cPanel > MySQL Databases
DB_HOST=localhost
DB_USER=cpanel_db_user
DB_PASSWORD=your_db_password
DB_NAME=salesorbit

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# OTP expiry in milliseconds (10 minutes)
OTP_EXPIRES_MS=600000

BCRYPT_ROUNDS=10

# SMTP — Gmail example (use App Password, not account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

FROM_EMAIL=noreply@salesorbit.io
FROM_NAME=SalesOrbit CRM

# In production: your actual domain
FRONTEND_URL=https://yourdomain.com
